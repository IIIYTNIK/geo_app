<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.geoapp.controller.SettingsController"
      alignment="CENTER" spacing="15" style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Text text="Настройки подключения к серверу" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Label text="IP адрес:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="ipField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"
                   promptText="192.168.0.1"/>

        <Label text="Порт:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="portField" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200"
                   promptText="8081"/>
    </GridPane>

    <Label fx:id="statusLabel" textFill="green" wrapText="true" maxWidth="300"/>

    <HBox alignment="CENTER" spacing="15">
        <Button text="Сохранить" onAction="#saveSettings" defaultButton="true"/>
        <Button text="Отмена" onAction="#closeWindow" cancelButton="true"/>
    </HBox>

</VBox>