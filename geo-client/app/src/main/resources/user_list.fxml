<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.geoapp.controller.UserListController"
      prefWidth="600">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
            <TableColumn fx:id="colLogin" text="Логин" prefWidth="170"/>
            <TableColumn fx:id="colFullName" text="ФИО" prefWidth="220"/>
            <TableColumn fx:id="colRole" text="Роль" prefWidth="160"/>
            <TableColumn fx:id="colPosition" text="Должность" prefWidth="220"/>
        </columns>
    </TableView>



    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="140" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Логин:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="loginField" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="ФИО:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="fullNameField" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Пароль:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <PasswordField fx:id="passwordField" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity"/>
        <Label text="Оставьте пустым, если пароль менять не нужно"
               style="-fx-text-fill: #777; -fx-font-size: 10px;"
               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Роль:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="roleCombo" GridPane.rowIndex="4" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Должность:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="positionField" GridPane.rowIndex="5" GridPane.columnIndex="1" maxWidth="Infinity"/>
    </GridPane>

    <Label fx:id="errorLabel" textFill="red" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="clearButton" text="Сбросить (для новой записи)" onAction="#onClearSelection"/>
        <Button fx:id="deleteButton" text="Удалить" onAction="#onDelete"/>
        <Button fx:id="saveButton" text="Добавить пользователя" onAction="#onSave"
                style="-fx-font-weight: bold; -fx-base: #1976D2; -fx-text-fill: white;"/>
    </HBox>
</VBox>