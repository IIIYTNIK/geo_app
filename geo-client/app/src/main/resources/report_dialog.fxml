<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.geoapp.controller.ReportDialogController"
      prefWidth="560">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="Шаблон отчёта" style="-fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
            <ComboBox fx:id="comboTemplate" maxWidth="Infinity"/>
        </VBox>
        <Button fx:id="btnDownload" text="Скачать шаблон" onAction="#onDownloadTemplate"/>
        <Button fx:id="btnDelete" text="Удалить шаблон" onAction="#onDeleteTemplate"/>
    </HBox>

    <Label text="Описание шаблона" style="-fx-font-weight: bold;"/>
    <Label fx:id="labelDescription" wrapText="true" minHeight="40" 
        style="-fx-font-style: italic; -fx-text-fill: #555;" text="Нет описания"/>
        
    <Label text="Формат" style="-fx-font-weight: bold;"/>
    <ComboBox fx:id="comboFormat" prefWidth="180"/>

    <Separator/>

    <Label text="Параметры шаблона" style="-fx-font-weight: bold;"/>
    <ScrollPane fitToWidth="true" prefHeight="320" VBox.vgrow="ALWAYS">
        <content>
            <VBox fx:id="paramsBox" spacing="10" fillWidth="true"/>
        </content>
    </ScrollPane>

    <Label fx:id="statusLabel" text="" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnUpload" text="Загрузить шаблон" onAction="#onUploadTemplate"/>
        <Button text="Обновить список" onAction="#onRefreshTemplatesClick"/>
        <Button fx:id="btnGenerate" text="Сформировать" onAction="#onGenerateClick"
                style="-fx-base: #1976D2; -fx-text-fill: white;"/>
    </HBox>
</VBox>