<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.geoapp.controller.WorkingFormController" prefWidth="550" prefHeight="750" spacing="0">
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <VBox spacing="10" style="-fx-padding: 20;">
            <Label text="* — обязательное поле, его нужно заполнить обязательно" style="-fx-text-fill: red; -fx-font-size: 12px;"/>

            <Label text="Участок:"/> <ComboBox fx:id="areaCombo" prefWidth="400"/>
            <Label text="Тип выработки:"/> <ComboBox fx:id="workTypeCombo" prefWidth="400"/>
            <Label text="Подрядчик:"/> <ComboBox fx:id="contractorCombo" prefWidth="400"/>
            <Label text="Геолог:"/> <ComboBox fx:id="geologistCombo" prefWidth="400"/>
            <Label text="Буровая:"/> <ComboBox fx:id="drillingRigCombo" prefWidth="400"/>
            
            <Label text="Номер*:"/> <TextField fx:id="numberField"/>
            
            <HBox spacing="10">
                <VBox HBox.hgrow="ALWAYS"><Label text="План X:"/><TextField fx:id="plannedXField"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="План Y:"/><TextField fx:id="plannedYField"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="План H:"/><TextField fx:id="plannedDepthField"/></VBox>
            </HBox>
            
            <HBox spacing="10">
                <VBox HBox.hgrow="ALWAYS"><Label text="Факт X:"/><TextField fx:id="actualXField"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="Факт Y:"/><TextField fx:id="actualYField"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="Факт Z:"/><TextField fx:id="actualZField"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="Факт H:"/><TextField fx:id="actualDepthField"/></VBox>
            </HBox>
            
            <Label fx:id="deltaSLabel" text="Смещение от проекта: не определено" style="-fx-text-fill: #555; -fx-font-style: italic;"/>

            <HBox spacing="10">
                <VBox HBox.hgrow="ALWAYS"><Label text="Выход керна, %:"/><TextField fx:id="coreRecoveryField"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="Обсад:"/><TextField fx:id="casingField"/></VBox>
            </HBox>

            <HBox spacing="10">
                <VBox HBox.hgrow="ALWAYS"><Label text="Дата начала:"/><DatePicker fx:id="startDatePicker" HBox.hgrow="ALWAYS"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="Дата окончания:"/><DatePicker fx:id="endDatePicker" HBox.hgrow="ALWAYS"/></VBox>
            </HBox>

            <HBox spacing="10">
                <VBox HBox.hgrow="ALWAYS"><Label text="ММГ1 кровля:"/><TextField fx:id="mmg1TopField"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="ММГ1 подошва:"/><TextField fx:id="mmg1BottomField"/></VBox>
            </HBox>

            <HBox spacing="10">
                <VBox HBox.hgrow="ALWAYS"><Label text="ММГ2 кровля:"/><TextField fx:id="mmg2TopField"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="ММГ2 подошва:"/><TextField fx:id="mmg2BottomField"/></VBox>
            </HBox>

            <HBox spacing="10">
                <VBox HBox.hgrow="ALWAYS"><Label text="ПУГВ (УГВ появ):"/><TextField fx:id="gwAppearLogField"/></VBox>
                <VBox HBox.hgrow="ALWAYS"><Label text="УУГВ (УГВ устан):"/><TextField fx:id="gwStableLogField"/></VBox>
            </HBox>
            <Label fx:id="gwStableAbsLabel" text="УУГВ абс: не определено" style="-fx-text-fill: #555;"/>

            <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                <CheckBox fx:id="actCheckBox" text="Акт"/>
                <VBox><Label text="Номер акта:"/><TextField fx:id="actNumberField" prefWidth="150"/></VBox>
            </HBox>

            <CheckBox fx:id="thermalTubeCheckBox" text="Термотрубка" style="-fx-padding: 5 0 10 0;"/>

            <Label text="Комментарий:"/><TextArea fx:id="additionalInfoArea" prefRowCount="3"/>
            
            <Label fx:id="errorLabel" textFill="red"/>
        </VBox>
    </ScrollPane>
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10; -fx-background-color: #f4f4f4;">
        <Button fx:id="saveButton" text="Сохранить" onAction="#onSave" prefWidth="100" style="-fx-font-weight: bold;" defaultButton="true"/>
        <Button fx:id="cancelButton" text="Отмена" onAction="#onCancel" prefWidth="100"/>
    </HBox>
</VBox>