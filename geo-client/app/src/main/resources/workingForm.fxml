<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.geoapp.controller.WorkingFormController"
      spacing="10" prefWidth="450">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Участок:"/>
    <ComboBox fx:id="areaCombo" prefWidth="400"/>

    <Label text="Тип выработки:"/>
    <ComboBox fx:id="workTypeCombo" prefWidth="400"/>

    <Label text="Геолог:"/>
    <ComboBox fx:id="geologistCombo" prefWidth="400"/>

    <Label text="Подрядчик:"/>
    <ComboBox fx:id="contractorCombo" prefWidth="400"/>

    <Label text="Буровая:"/>
    <ComboBox fx:id="drillingRigCombo" prefWidth="400"/>

    <Label text="Номер*:"/>
    <TextField fx:id="numberField"/>

    <HBox spacing="10">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="План X:"/>
            <TextField fx:id="plannedXField"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS">
            <Label text="План Y:"/>
            <TextField fx:id="plannedYField"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS">
            <Label text="План Z:"/>
            <TextField fx:id="plannedZField"/>
        </VBox>
    </HBox>

    <HBox spacing="10">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Факт X:"/>
            <TextField fx:id="actualXField"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Факт Y:"/>
            <TextField fx:id="actualYField"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Факт Z:"/>
            <TextField fx:id="actualZField"/>
        </VBox>
    </HBox>

    <Label text="Глубина:"/>
    <TextField fx:id="depthField"/>

    <Label text="Дата начала:"/>
    <DatePicker fx:id="startDatePicker" promptText="ГГГГ-ММ-ДД"/>

    <Label text="Дата окончания:"/>
    <DatePicker fx:id="endDatePicker" promptText="ГГГГ-ММ-ДД"/>

    <Label text="Доп. информация:"/>
    <TextArea fx:id="additionalInfoArea" prefRowCount="3"/>

    <Label fx:id="errorLabel" textFill="red"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="saveButton" text="Сохранить" onAction="#onSave"/>
        <Button fx:id="cancelButton" text="Отмена" onAction="#onCancel"/>
    </HBox>
</VBox>