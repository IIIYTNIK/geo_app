            <textField>
                <reportElement x="0" y="40" width="400" height="20" uuid="12345678-1234-1234-1234-123456789014"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA["на участке " + $P{AREA_ID} + " подрядчиком " + $P{CONTRACTOR_ID} + " за период с " + ($P{REPORT_START} != null ? $P{REPORT_START}.format("dd.MM.yyyy") : "...") + " по " + ($P{REPORT_END} != null ? $P{REPORT_END}.format("dd.MM.yyyy") : "...")]]></textFieldExpression>
