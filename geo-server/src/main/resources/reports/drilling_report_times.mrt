        <CommandTimeout>30</CommandTimeout>
        <Dictionary isRef="1" />
        <Key>561eba937ed04f7cbbde38dad9d3e87f</Key>
        <Name>workings2</Name>
        <NameInSource>PostgreSQL</NameInSource>
        <Parameters isList="true" count="0" />
        <SqlCommand>SELECT 
	w.number AS "Наименование скважины",
	w.actual_depth AS "H",
	w.actualx AS "X факт",
	w.actualy AS "Y факт",
	w.actualz AS "Z факт",
	w.start_date AS "Дата начала бурения",
	w.end_date AS "Дата окончания бурения",
	g.name AS "Геолог",
	c.name AS "Подрядчик",
	a.name AS "Участок",
	w.cat1_4 AS "cat1_4",
	w.cat5_8 AS "cat5_8",
	w.cat9_12 AS "cat9_12"
	FROM workings w
LEFT JOIN ref_geologists g ON w.geologist_id = g.id
LEFT JOIN ref_contractors c ON w.contractor_id = c.id
LEFT JOIN ref_areas a ON w.area_id = a.id
WHERE (w.contractor_id = {contractorId} OR {contractorId} = 0)
  AND (w.area_id = {areaId} OR {areaId} = 0)
  AND w.start_date &gt;= TO_DATE('{ReportStart}', 'DD.MM.YYYY')
  AND w.end_date &lt;= TO_DATE('{ReportEnd}', 'DD.MM.YYYY')
ORDER BY w.start_date, w.number</SqlCommand>
      </workings2>
    </DataSources>
