<jasperReport name="Test_first" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="9802bc51-7232-4bc4-b335-51a59d1db086">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Geo_app"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<query language="sql"><![CDATA[SELECT
    w.actualx,
    w.actualy,
    w.actualz,
    w.actual_depth,
    w.start_date,
    w.end_date,

    CONCAT(
        SUBSTRING(wt.name FROM 1 FOR 1),
        '-',
        w.number
    ) AS full_working_name,
    
    c.name  AS contractor_name,
    a.name  AS area_name,
    g.name  AS geologist_name,
    g.alias AS geologist_alias,
    dr.name AS drilling_rig_name,
    wt.name AS work_type_name

FROM public.workings w

LEFT JOIN ref_contractors c ON w.contractor_id = c.id
LEFT JOIN ref_areas a ON w.area_id = a.id
LEFT JOIN ref_geologists g ON w.geologist_id = g.id
LEFT JOIN ref_drilling_rigs dr ON w.drilling_rig_id = dr.id
LEFT JOIN ref_work_types wt ON w.work_type_id = wt.id;]]></query>
